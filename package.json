{
  "name": "ura-helper",
  "version": "0.1.0",
  "private": true,
  "productName": "Ura Helper",
  "description": "No-focus Windows helper overlay with leader and viewer modes.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "relay": "node server/relay.js",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer/app.js && node --check server/relay.js && node --check server/public/app.js",
    "build": "electron-builder --win portable",
    "build:publish": "npm run build && node scripts/publish-build.js"
  },
  "build": {
    "appId": "site.syrion.ura-helper",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}
