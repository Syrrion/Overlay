{
  "name": "ura-helper",
  "version": "0.1.0",
  "private": true,
  "productName": "Ura Helper",
  "description": "No-focus Windows helper overlay with leader and viewer modes.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "relay": "node server/relay.js",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer/app.js && node --check server/relay.js && node --check server/public/app.js",
    "build": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg --arm64 --publish never"
  },
  "build": {
    "appId": "site.syrion.ura-helper",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Ura-Helper-v${env.CLIENT_VERSION}-windows-${arch}-installer.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "artifactName": "Ura-Helper-v${env.CLIENT_VERSION}-macos-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  }
}
